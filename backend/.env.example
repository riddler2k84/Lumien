# App
APP_MODE=production          # production | demo
APP_NAME=Frontier International
APP_SHORT_NAME=Lúmien
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/school_scheduler

# Currency (no conversion — single active currency)
DEFAULT_CURRENCY=MYR
CURRENCY_SYMBOL=RM

# School identity
SCHOOL_TYPE=Private School   # Tuition Center | International Primary School | International Secondary School | Day Care | Private School
SCHOOL_COUNTRY=Malaysia

# Demo mode reset schedule (cron expression, runs nightly at 2am)
DEMO_RESET_CRON=0 2 * * *
