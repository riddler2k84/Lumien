# App
APP_NAME=Frontier International
APP_SHORT_NAME=Lúmien
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Databases (one per tenant — separate SQLite files for local dev, PostgreSQL URLs for prod)
PRODUCTION_DATABASE_URL=sqlite:///./production.db
DEMO_DATABASE_URL=sqlite:///./demo.db

# Currency (no conversion — single active currency)
DEFAULT_CURRENCY=MYR
CURRENCY_SYMBOL=RM

# School identity
SCHOOL_TYPE=Private School   # Tuition Center | International Primary School | Day Care | Private School
SCHOOL_COUNTRY=Malaysia

# Demo tenant nightly reset schedule (cron expression)
DEMO_RESET_CRON=0 2 * * *
